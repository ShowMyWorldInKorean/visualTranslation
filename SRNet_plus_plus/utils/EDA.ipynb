   "source": [
    "with open('./eng_hin.txt', 'r') as f:\n",
    "    lines = f.readlines()\n",
    "\n",
    "# split data small size\n",
    "\n",
    "for i in range(0, len(lines), 100):\n",
    "    with open(f'./eng_hin_{i}.txt', 'w') as f:\n",
    "        f.writelines(lines[i:i+100])\n"
   ]
  }
